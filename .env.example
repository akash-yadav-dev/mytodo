# Application
APP_NAME=MyTodo
APP_ENV=development
APP_PORT=8080
APP_URL=http://localhost:8080

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=mytodo
DB_PASSWORD=mytodo_dev_password
DB_NAME=mytodo_dev
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=300s

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=mytodo_redis_password
REDIS_DB=0
REDIS_POOL_SIZE=10

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=mytodo
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# NATS Message Queue
NATS_URL=nats://localhost:4222
NATS_CLUSTER_ID=mytodo-cluster
NATS_CLIENT_ID=mytodo-api

# MinIO / S3 Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=mytodo-attachments
MINIO_USE_SSL=false
MINIO_REGION=us-east-1

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d
JWT_ISSUER=mytodo-api

# OAuth - Google
OAUTH_GOOGLE_CLIENT_ID=your-google-client-id
OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH_GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/callback/google

# OAuth - GitHub
OAUTH_GITHUB_CLIENT_ID=your-github-client-id
OAUTH_GITHUB_CLIENT_SECRET=your-github-client-secret
OAUTH_GITHUB_REDIRECT_URL=http://localhost:8080/api/v1/auth/callback/github

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_ADDRESS=noreply@mytodo.com
SMTP_FROM_NAME=MyTodo

# Email (SendGrid alternative)
SENDGRID_API_KEY=your-sendgrid-api-key
USE_SENDGRID=false

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_OUTPUT=stdout

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=100

# CORS
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOW_CREDENTIALS=true

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/plain

# Session
SESSION_TIMEOUT=24h
MAX_SESSIONS_PER_USER=5

# Security
BCRYPT_COST=10
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9091

# Tracing
JAEGER_ENABLED=false
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Webhooks
WEBHOOK_TIMEOUT=30s
WEBHOOK_MAX_RETRY=3

# Feature Flags
FEATURE_ELASTICSEARCH_ENABLED=true
FEATURE_OAUTH_ENABLED=true
FEATURE_EMAIL_ENABLED=false
FEATURE_NOTIFICATIONS_ENABLED=true
FEATURE_WEBHOOKS_ENABLED=false

# Development
DEBUG_MODE=true
ENABLE_PROFILER=true
ENABLE_SWAGGER=true
